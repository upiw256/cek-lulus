# 1. Koneksi Database (MongoDB)
# Jika pakai Docker/Local: mongodb://localhost:27017/nama_db_kamu
# Jika pakai MongoDB Atlas: mongodb+srv://user:pass@cluster.mongodb.net/nama_db
MONGODB_URI=
# 2. Keamanan Admin
# Ganti dengan password yang sangat rahasia untuk login admin
ADMIN_PASSWORD=admin123
JWT_SECRET=

# 3. Pengaturan Aplikasi
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SCHOOL_NAME=""